---
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
  permalink: string;
}

let {
  title,
  description = "I'm Karla Vasquez, a Peruvian American recent Computer Engineering and Computer Science grad at the University of Southern California.",
  permalink,
} = Astro.props;
title = `Karla Vasquez | ${title}`;
const resolvedPermalink = Astro.site
  ? new URL(permalink, Astro.site).toString()
  : null;

const meta = "/assets/meta.png";
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<!-- <link rel="manifest" href="/site.webmanifest" /> -->
<link rel="mask-icon" href="/safari-pinned-tab.svg" color="#e7b7ad" />
<link rel="shortcut icon" href="/favicon.ico" />
<meta name="msapplication-TileColor" content="#f9ecea" />
<meta name="msapplication-config" content="/browserconfig.xml" />
<meta name="theme-color" content="#f9ecea" />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
{resolvedPermalink && <link rel="canonical" href={resolvedPermalink} />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
{resolvedPermalink && <meta property="og:url" content={resolvedPermalink} />}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={meta} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
{resolvedPermalink && <meta property="twitter:url" content={resolvedPermalink} />}
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={meta} />

<link rel="icon" type="image/png" sizes="48x48" href="/favicon.png" />
<!-- Font Links -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Inconsolata:wght@400;500;600;700&display=swap"
  rel="stylesheet"
/>



<ViewTransitions />
