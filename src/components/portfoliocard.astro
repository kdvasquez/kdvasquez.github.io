---
import ButtonBar from "@components/buttonbar.astro";
import ButtonTag from "@components/buttontag.astro";
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

export interface Props {
  image: boolean;
  body: boolean;
  title: string;
  date: string;
  description: string;
  url: string;
  imageUrl: string;
  tags: string[];
  featured?: boolean;
}

const { image, body, title, date, description, url, imageUrl, tags } =
  Astro.props;
const isExternal = /^(https?:)?\/\//.test(url);
const hasCustomUrl = url.trim().length > 0;

const newDate = new Date(`${date}T00:00:00`);
const options: Intl.DateTimeFormatOptions = {
  year: "numeric",
  month: "long",
  day: "numeric",
};
const formatDate = newDate.toLocaleDateString("en-US", options);

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/portfolio/*.{jpeg,jpg,png,gif,webp}"
);

if (imageUrl != "" && !images[imageUrl])
  throw new Error(
    `"${imageUrl}" does not exist in glob: "src/assets/portfolio/*.{jpeg,jpg,png,gif,webp}"`
  );

const imageMeta = await images[imageUrl]();
const href = !body ? (hasCustomUrl ? url : imageMeta.default.src) : url;
const opensNewTab = isExternal || !body;
---

<article class="card">
  {opensNewTab ? (
    <a class="cardlink" href={href} target="_blank" rel="noreferrer">
      <div class="content">
        {
          body ? (
            <div class="card-content">
              {image && (
                <div class="image-container">
                  <Image
                    class="img-content"
                    src={imageMeta.default}
                    width="400"
                    alt={description}
                  />
                </div>
              )}
              
              <div class="text">
                <div class="header">
                  <h3 class="title">{title}</h3>
                  <span class="date">{formatDate}</span>
                </div>
                <p class="description">{description}</p>
                <ButtonBar>
                  {tags.map((tag) => (
                    <ButtonTag>{tag}</ButtonTag>
                  ))}
                </ButtonBar>
              </div>
            </div>
          ) : (
            <div class="image-wrapper">
              <Image
                class="img-content"
                src={imageMeta.default}
                width="800"
                alt={description}
              />
              <div class="hover-overlay">
                <div class="overlay-content">
                  <h3 class="overlay-title">{title}</h3>
                  <p class="overlay-description">{description}</p>
                  <span class="overlay-date">{formatDate}</span>
                </div>
              </div>
            </div>
          )
        }
      </div>
    </a>
  ) : (
    <a class="cardlink" href={href}>
      <div class="content">
        {
          body ? (
            <div class="card-content">
              {image && (
                <div class="image-container">
                  <Image
                    class="img-content"
                    src={imageMeta.default}
                    width="400"
                    alt={description}
                  />
                </div>
              )}
              
              <div class="text">
                <div class="header">
                  <h3 class="title">{title}</h3>
                  <span class="date">{formatDate}</span>
                </div>
                <p class="description">{description}</p>
                <ButtonBar>
                  {tags.map((tag) => (
                    <ButtonTag>{tag}</ButtonTag>
                  ))}
                </ButtonBar>
              </div>
            </div>
          ) : (
            <div class="image-wrapper">
              <Image
                class="img-content"
                src={imageMeta.default}
                width="800"
                alt={description}
              />
              <div class="hover-overlay">
                <div class="overlay-content">
                  <h3 class="overlay-title">{title}</h3>
                  <p class="overlay-description">{description}</p>
                  <span class="overlay-date">{formatDate}</span>
                </div>
              </div>
            </div>
          )
        }
      </div>
    </a>
  )}
</article>

<style lang="scss">
  .card {
    break-inside: avoid;
    margin-bottom: 0;
  }

  .card:hover {
    transform: scale(1.01);
    transition: 0.3s;
  }

  .card:active {
    transform: scale(0.98);
    transition: 0.3s;
  }

  .cardlink {
    color: inherit;
    text-decoration: none;
    box-shadow: none;
    padding: 0;
    transition: none;
    font-weight: inherit;
    display: block;
  }

  .cardlink:hover {
    color: inherit;
    background: none;
  }

  .cardlink:visited {
    color: inherit;
  }

  .content {
    box-shadow: var(--carddrop);
    margin-bottom: 0;
    break-inside: avoid;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    border: 0.5px solid var(--light);
  }

  .image-container {
    width: 100%;
    height: 140px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .img-content {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    display: block;
    background: var(--pale);
  }

  .image-wrapper {
    position: relative;
    overflow: hidden;
    height: 140px;
  }

  .hover-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    padding: 24px;
  }

  .image-wrapper:hover .hover-overlay {
    opacity: 1;
  }

  .overlay-content {
    color: white;
    text-align: center;
    max-width: 90%;
  }

  .overlay-title {
    font-size: 1.25rem;
    font-weight: bold;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .overlay-description {
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .overlay-date {
    font-size: 0.85rem;
    font-style: oblique;
    opacity: 0.9;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    background-color: white;
  }

  .text {
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .title {
    font-size: 16px;
    font-weight: 500;
    margin: 0;
    color: var(--dark);
  }

  .date {
    font-size: 12px;
    font-style: oblique;
    color: var(--med);
    margin: 0;
  }

  .description {
    font-size: 13px;
    color: var(--med);
    margin: 0;
    line-height: 1.5;
  }
</style>