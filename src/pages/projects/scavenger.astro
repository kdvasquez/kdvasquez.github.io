    margin-bottom: 1.5rem;
    border-radius: 8px;
    box-shadow: var(--photodrop);

    h3 {
      margin-top: 0;
      color: var(--med);
    }

    p {
      margin-bottom: 0.75rem;

      strong {
        color: var(--med);
      }

      &:last-child {
