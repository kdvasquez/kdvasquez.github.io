      }
    }
  }

  .screenshot-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;

    &.single {
      grid-template-columns: 1fr;
      max-width: 640px;
      margin-left: auto;
      margin-right: auto;
    }

    @media (max-width: 768px) {
      grid-template-columns: 1fr;
    }
  }

  .screenshot {
    text-align: center;

    img {
      width: 100%;
      height: auto;
      border-radius: 8px;
      box-shadow: var(--carddrop);
    }

    .caption {
      margin-top: 0.5rem;
      font-size: 0.9rem;
      color: var(--med);
      font-style: italic;
    }
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .stat-item {
    text-align: center;
    padding: 1.5rem;
    background-color: var(--light);
    border-radius: 8px;

    .stat-number {
      display: block;
      font-size: 2.25rem;
      font-weight: bold;
      color: var(--med);
      margin-bottom: 0.5rem;
    }

    .stat-label {
      display: block;
      font-size: 0.85rem;
      color: var(--black);
      line-height: 1.4;
    }
  }

  @media (max-width: 768px) {
    .stats,
    .arch-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>